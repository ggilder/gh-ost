FROM ubuntu:22.04

# Install dependencies
RUN apt-get update -qq && \
    apt-get install -y -qq wget git mysql-client sysbench && \
    rm -rf /var/lib/apt/lists/*

# Install Go 1.24.13
RUN cd /tmp && \
    wget -q https://go.dev/dl/go1.24.13.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go1.24.13.linux-amd64.tar.gz && \
    rm go1.24.13.linux-amd64.tar.gz

# Set Go environment
ENV PATH=/usr/local/go/bin:$PATH \
    GOROOT=/usr/local/go

# Verify installation
RUN go version

WORKDIR /gh-ost
